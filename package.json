{
	"name": "neuropilot-companion-template",
	"displayName": "NeuroPilot Companion Template",
	"description": "Template for a NeuroPilot companion extension",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.116.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "neuropilot-companion-template.helloWorld",
				"title": "Hello World"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src",
		"test": "vscode-test"
	},
	"extensionDependencies": [
		"vsc-neuropilot.neuropilot-base"
	],
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.19.17",
		"@types/vscode": "^1.116.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"eslint": "^9.39.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"dependencies": {
		"@vsc-neuropilot/api-types": "1.0.0-pre.7"
	}
}
