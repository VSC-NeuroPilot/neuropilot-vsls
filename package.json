{
	"name": "neuropilot-vsls",
	"displayName": "VSC-NeuroPilot",
	"description": "Visual Studio Live Share companion forr NeuroPilot",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.116.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "neuropilot-companion-template.helloWorld",
				"title": "Hello World"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm run build",
		"build": "npm-run-all -s build:*",
		"build:tsc": "tsc -p ./",
		"build:esbuild": "node ./scripts/esbuild.mjs",
		"watch": "npm-run-all -p watch:*",
		"watch:tsc": "tsc -watch -p ./",
		"watch:esbuild": "node./scripts/esbuild.mjs",
		"lint": "eslint src",
		"test": "vscode-test",
		"package": "vsce package --no-dependencies"
	},
	"extensionDependencies": [
		"vsc-neuropilot.neuropilot-base"
	],
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "^24.12.0",
		"@types/vscode": "^1.116.0",
		"@vscode/test-cli": "^0.0.15",
		"@vscode/test-electron": "^3.0.0",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"npm-run-all2": "^9.0.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0"
	},
	"dependencies": {
		"@vsc-neuropilot/api-types": "1.0.0-pre.14",
		"@vsc-neuropilot/vsls-redux": "^0.0.0",
		"zod": "^4.4.3"
	}
}
